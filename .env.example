# Database
DATABASE_URL=postgresql://postgres:admin@localhost:5432/shopify_products

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Shopify (Dev Dashboard app - post Jan 2026)
# Get SHOPIFY_CLIENT_ID and SHOPIFY_CLIENT_SECRET from the Dev Dashboard app credentials page.
# The access token is fetched automatically via client credentials grant - no need to set it manually.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# Storage (local for dev, s3 for prod)
STORAGE_BACKEND=local
STORAGE_PATH=./uploads
# AWS_S3_BUCKET=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# App
SECRET_KEY=change-this-to-a-random-secret-key-in-production
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
